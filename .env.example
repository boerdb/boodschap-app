# Kopieer naar .env.local:
#   cp .env.example .env.local
#
# MySQL: server DB (192.168.1.14) — database boodschap
# Next.js: lokaal of server NEXT (192.168.1.32)

DATABASE_URL=mysql://boodschap:JOUW_DB_WACHTWOORD@192.168.1.14:3306/boodschap

NODE_ENV=development
APP_TIMEZONE=Europe/Amsterdam

# Optioneel: telefoon opzelfde Wi‑Fi tijdens npm run dev
# ALLOWED_DEV_ORIGINS=192.168.1.120

# Fase 2 — prijzen (Checkjebon in MariaDB + Redis op .14, zie docs/PRICES.md)
# DATABASE_URL=mysql://boodschap:...@192.168.1.14:3306/boodschap
# REDIS_URL=redis://192.168.1.14:6379
# REDIS_URL=redis://:wachtwoord@192.168.1.14:6379
